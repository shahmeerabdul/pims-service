# ==============================================================================
# PIMS Production Environment Variables Configuration Template
# Copy this file to 'env.production' and fill in the values before deploying.
# ==============================================================================

# Core Django Settings
DEBUG=False
SECRET_KEY=generate_your_own_secure_key_here_e_g_token_urlsafe

# Database Connection (Format: postgres://user:pass@host:port/dbname)
# Note: 'db' refers to the database service defined in docker-compose.yml
DATABASE_URL=postgres://psych_user:db_password_here@db:5432/psych_db

# Allowed hostnames (comma-separated). Set to * or specify your custom domain/IP.
ALLOWED_HOSTS=*

# Redis cache connection URL
REDIS_URL=redis://redis:6379/0

# Allowed CORS & CSRF origins for secure cross-site communications
# Replace IP and domain with your target VM address or custom domain
CORS_ALLOWED_ORIGINS=http://localhost:4756,http://127.0.0.1:4756,http://your_server_ip:4756,https://yourdomain.com,http://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:4756,http://127.0.0.1:4756,http://your_server_ip:4756,https://yourdomain.com,http://yourdomain.com

# Database Container Configuration
POSTGRES_DB=psych_db
POSTGRES_USER=psych_user
POSTGRES_PASSWORD=db_password_here

# Transactional Email Server Settings (Brevo SMTP configuration)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_brevo_smtp_login_email_here
EMAIL_HOST_PASSWORD=your_brevo_smtp_key_here
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com

# Frontend API Endpoint
# Tells the React frontend where the backend API routes are served
VITE_API_URL=https://yourdomain.com/api

# Nginx Routing Port Configuration
# Set the port that the Docker stack should bind to on the host VM (default is 4756)
NGINX_PORT=4756
