# Django Settings
SECRET_KEY=django-insecure-dev-key-123456789
DEBUG=True
NGINX_PORT=80
ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=adminpass
DJANGO_LOG_LEVEL=INFO

# Security (Only needed if DEBUG=False)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000

# PostgreSQL Database
POSTGRES_DB=psych_db
POSTGRES_USER=psych_user
POSTGRES_PASSWORD=psych_pass
DATABASE_URL=postgres://psych_user:psych_pass@db:5432/psych_db

# Redis Cache
REDIS_URL=redis://redis:6379/0

# Email (Brevo SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@psycheversity.com
PARTICIPANT_EMAIL_FROM=Psycheversity Research Team <support@psycheversity.com>
PARTICIPANT_EMAIL_REPLY_TO=support@psycheversity.com
SITE_BASE_URL=http://localhost

# Frontend
VITE_API_URL=http://localhost:8000/api
CORS_ALLOWED_ORIGINS=http://localhost:5173
